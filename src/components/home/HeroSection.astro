---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import { getCheckoutUrl } from "../../lib/checkout";

const checkoutUrl = getCheckoutUrl({ content: "hero", medium: "hero" });

// Week 5 – Hero video (R2 test asset)
// Later you can swap only the file URLs below and keep the component unchanged.
const heroVideoUrl = "https://pub-8b341dd923b44e5a8332a91f57cd8601.r2.dev/hero/hero-video.mp4";
const heroPosterUrl = "https://cdn.facialvolumeharmony.com/hero/hero-poster-v2.PNG";
---

<section class="hero" aria-labelledby="hero-title">
  <Container>
    <div class="hero__grid">
      <div class="hero__copy">
        <p class="kicker">A natural approach to facial balance</p>
        <h1 id="hero-title" class="hero__title">Lift and define your face — naturally.</h1>
        <p class="hero__lead muted">
          A structured facial training program combining tongue posture, breathing, and gentle techniques to support natural facial balance and definition. <b>Gentle. Structured. Sustainable.</b>
        </p>

        <div class="hero__cta">
          <Button
            href={checkoutUrl}
            variant="primary"
            target="_blank"
            rel="noreferrer"
            data-ff-event="checkout_click"
            data-ff-content="hero"
            data-ff-outbound="checkout"
          >
            Get access now
          </Button>

          <Button
            href="#free-tips"
            variant="secondary"
            data-ff-event="scroll_click"
            data-ff-content="hero_to_free_tips"
          >
            Get $20 off
          </Button>
        </div>

        <div class="hero__meta" aria-label="Course highlights">
          <div class="hero__metaItem">
            <div class="hero__metaLabel">Routine</div>
            <div class="hero__metaValue">10–15 min/day</div>
          </div>
          <div class="hero__metaItem">
            <div class="hero__metaLabel">Approach</div>
            <div class="hero__metaValue">Gentle & consistent</div>
          </div>
          <div class="hero__metaItem">
            <div class="hero__metaLabel">Level</div>
            <div class="hero__metaValue">Beginner-friendly</div>
          </div>
        </div>
      </div>

      <div class="hero__image">
        <div class="hero__imgPanel">
          <div class="hero__imgTop">
            <span class="hero__imgBadge">Start here</span>
            <span class="hero__imgSmall muted">Understand what changes your face</span>
          </div>

          <div class="hero__media" data-hero-video-wrap>
            <!-- Week 5 – Hero video (R2 test asset) -->
            <video
              class="hero__video"
              preload="metadata"
              poster={heroPosterUrl}
              controls
              playsinline
              data-hero-video
              aria-label="Face Fitness course preview video"
            >
              <source src={heroVideoUrl} type="video/mp4" />
              Your browser does not support the video tag.
            </video>

            <button
              class="hero__playButton"
              type="button"
              aria-label="Play video"
              data-hero-play
            >
              <span class="hero__playIcon" aria-hidden="true"></span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </Container>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const wrap = document.querySelector("[data-hero-video-wrap]");
      const video = document.querySelector("[data-hero-video]");
      const playButton = document.querySelector("[data-hero-play]");

      if (!wrap || !video || !playButton) return;

      const showOverlay = () => {
        wrap.classList.remove("is-playing");
      };

      const hideOverlay = () => {
        wrap.classList.add("is-playing");
      };

      playButton.addEventListener("click", async () => {
        try {
          video.muted = false;
          await video.play();
          hideOverlay();
        } catch (error) {
          console.error("Hero video could not start:", error);
        }
      });

      video.addEventListener("play", hideOverlay);
      video.addEventListener("pause", showOverlay);
      video.addEventListener("ended", showOverlay);
    });
  </script>

  <style>
    .hero{ padding: 84px 0 48px; }
    .hero__grid{
      display:grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 28px;
      align-items: center;
    }

    .hero__copy,
    .hero__image{
      min-width: 0;
    }

    .hero__title{
      font-size: clamp(42px, 5.2vw, 74px);
      margin: 10px 0 0;
      font-family: var(--font-serif);
    }
    .hero__lead{ margin: 14px 0 0; max-width: 62ch; font-size: 16px; color: #2F241E !important;}

    .hero__cta{ margin-top: 20px; display:flex; gap: 12px; flex-wrap: wrap; }

    .hero__meta{
      margin-top: 22px;
      display:grid;
      grid-template-columns: repeat(3, minmax(0,1fr));
      gap: 12px;
    }
    .hero__metaItem{
      border: 1px solid var(--line-2);
      border-radius: 16px;
      background: rgba(255,255,255,0.6);
      padding: 12px;
    }
    .hero__metaLabel{
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #4A342A;
    }
    .hero__metaValue{
      margin-top: 6px;
      font-family: var(--font-serif);
      font-size: 18px;
    }

    .hero__imgPanel{
      border-radius: 22px;
      border: 1px solid var(--line-2);
      background: rgba(255,255,255,0.65);
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .hero__imgTop{
      display:flex;
      align-items:center;
      justify-content: space-between;
      gap: 16px;
      padding: 12px 16px;
      border-bottom: 1px solid var(--line-2);
      background: rgba(255,255,255,0.75);
    }
    .hero__imgBadge{
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--paper);
      background: var(--accent);
      padding: 8px 12px;
      border-radius: 999px;
      flex: 0 0 auto;
    }
    .hero__imgSmall{
      font-size: 16px;
      line-height: 1.25;
      text-align: right;
      flex: 1 1 auto;
    }

    .hero__media{
      position: relative;
      width: 100%;
      min-height: 360px;
      aspect-ratio: 16 / 10;
      background:
        linear-gradient(180deg, rgba(107,63,34,0.08), transparent 55%),
        linear-gradient(90deg, rgba(17,17,17,0.04), rgba(17,17,17,0.02));
      overflow: hidden;
    }

    .hero__video{
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      background: #d9d2cc;
    }

    .hero__playButton{
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      width: 100%;
      height: 100%;
      border: 0;
      padding: 0;
      cursor: pointer;
      background:
        linear-gradient(180deg, rgba(17,17,17,0.08), rgba(17,17,17,0.2));
      transition: opacity 0.2s ease;
    }

    .hero__playButton:hover .hero__playIcon{
      transform: scale(1.04);
    }

    .hero__playIcon{
      width: 84px;
      height: 84px;
      border-radius: 999px;
      background: rgba(255,255,255,0.92);
      box-shadow: 0 10px 28px rgba(0,0,0,0.14);
      position: relative;
      transition: transform 0.2s ease;
    }

    .hero__playIcon::before{
      content: "";
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-40%, -50%);
      width: 0;
      height: 0;
      border-top: 12px solid transparent;
      border-bottom: 12px solid transparent;
      border-left: 18px solid #6b3f22;
    }

    .hero__media.is-playing .hero__playButton{
      opacity: 0;
      pointer-events: none;
    }

    @media (max-width: 900px){
      .hero{ padding: 58px 0 34px; }
      .hero__grid{ grid-template-columns: 1fr; }
      .hero__media{
        min-height: 280px;
      }
      .hero__meta{ grid-template-columns: 1fr; }

      .hero__imgTop{
        align-items: center;
      }

      .hero__imgSmall{
        font-size: 15px;
      }
    }

    @media (max-width: 560px){
      .hero__imgTop{
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
      }

      .hero__imgBadge{
        padding: 7px 12px;
      }

      .hero__imgSmall{
        font-size: 14px;
        line-height: 1.3;
        text-align: left;
      }
    }

    @media (hover: none) and (pointer: coarse){
      .hero__playButton{
        display: none;
      }
    }

    /*Custom CSS styles*/
    .hero {
      background: #C3B2A6 !important;
    }
    .kicker{
      color: #5A3320;
    }
    .hero__imgSmall {
      color: #3F3129 !important;
    }
  </style>
</section>