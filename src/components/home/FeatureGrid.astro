---
const items = [
  {
    title: "Firmer jawline",
    text: "Support natural facial posture and reduce tension for a more defined lower face.",
  },
  {
    title: "Fuller cheeks",
    text: "Encourage natural volume and lift through soft tissue work and better habits.",
  },
  {
    title: "More open look",
    text: "Improve breathing and tongue posture to support a more open, relaxed expression.",
  },
  {
    title: "Gentle & consistent",
    text: "A simple routine you can follow daily — no equipment needed.",
  },
];
---
<div class="grid grid--2">
  {items.map((x) => (
    <div class="card">
      <h3 class="h3">{x.title}</h3>
      <p class="muted">{x.text}</p>
    </div>
  ))}
</div>
