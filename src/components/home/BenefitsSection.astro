---
import Section from "../ui/Section.astro";
import FeatureGrid from "./FeatureGrid.astro";
---

<Section id="benefits" title="Key benefits">
  <div class="intro">
    <h2 class="title">Build healthy habits that shape your face</h2>
    <p class="muted">
      A structured approach to facial posture, muscle balance, and tension release — through gentle, consistent practice.
    </p>
  </div>

  <FeatureGrid />

  <style>
    .intro{ margin-bottom: 16px; max-width: 84ch; }
    .title{
      margin: 0 0 8px;
      font-family: var(--font-serif);
      font-size: clamp(30px, 3.8vw, 46px);
      line-height: 1.06;
      letter-spacing: -0.01em;
    }
    .intro p{ margin: 0; }
  </style>
</Section>
