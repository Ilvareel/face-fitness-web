---
import Section from "../ui/Section.astro";
import LeadMagnetForm from "../LeadMagnetForm.astro";
---

<Section id="free-tips" title="Free tips (email)">
  <div class="grid grid--2">
    <div class="card">
      <h3 class="h3">Get $20 off the full program</h3>
      <p class="muted">Leave your email and we’ll send you an exclusive discount code so you can access the full program at a reduced price.</p>
      <p class="muted discount-p">🎁 $119 → $99</p>
      <p class="muted">You’ll also receive a curated selection of articles to help you better understand:</p>

      <ul class="bullets">
        <li>what a harmonious face is — and why it changes over time</li>
        <li>whether facial exercises can really influence your appearance</li>
        <li>how to support a natural lift without invasive procedures</li>
      </ul>

      <p class="muted" style="margin-top:14px;">
        We respect your inbox. Unsubscribe anytime.
      </p>
    </div>

    <div class="formWrap">
      <LeadMagnetForm />
    </div>
  </div>

  <style>
    /* Keep form styles inside LeadMagnetForm; these are only layout helpers */
    .formWrap :global(.leadmagnet){
      display:block;
    }
    .formWrap :global(.leadmagnet__copy){
      margin-bottom: 10px;
    }
    .formWrap :global(#lead-form){
      margin-top: 6px;
    }
    .formWrap :global(.hp){
      position:absolute;
      left:-9999px;
      width:1px;
      height:1px;
      overflow:hidden;
    }
    .discount-p {
      color: #111;
      font-weight: 600;
      font-size: 18px;
    }
  </style>
</Section>
