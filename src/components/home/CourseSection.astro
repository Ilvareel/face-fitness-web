---
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
import { getCheckoutUrl } from "../../lib/checkout";

const checkoutUrl = getCheckoutUrl({ content: "course_section", medium: "section" });
---

<Section id="course" title="Course">
  <div class="grid grid--2">
    <div class="card">
      <h3 class="h3">What you get</h3>
      <ul class="bullets">
        <li>Step-by-step lessons with a clear daily routine</li>
        <li>Detailed technique guidance and common mistakes to avoid</li>
        <li>A structured path from beginner to consistent practice</li>
        <li>Lifetime access after purchase</li>
      </ul>
    </div>

    <div class="card join">
      <h3 class="h3">Join now</h3>
      <p class="muted">
        Get instant access to the full program after purchase. A clear, structured system you can follow at your own pace to build visible results over time.
      </p>
      <p class="muted">
        <i>Secure checkout and course access are handled through a trusted platform.</i>
      </p>

      <div class="cta">
        <Button
          href={checkoutUrl}
          variant="primary"
          target="_blank"
          rel="noreferrer"
          data-ff-event="checkout_click"
          data-ff-content="course_section"
          data-ff-outbound="checkout"
        >
          Join the course
        </Button>

        <Button
          href="#free-tips"
          variant="secondary"
          data-ff-event="scroll_click"
          data-ff-content="course_to_free_tips"
        >
          Get $20 off
        </Button>
      </div>

      <p class="note">$119 • Limited launch price • One-time payment • Lifetime access</p>
    </div>
  </div>

  <style>
    .cta{ margin-top: 12px; display:flex; gap: 12px; flex-wrap: wrap; }
    .note{ margin: 12px 0 0; font-size: 12px; color: rgba(17,17,17,0.58); }
  </style>
</Section>
