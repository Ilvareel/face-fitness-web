---
const steps = [
  { title: "Tongue posture", text: "Learn how proper tongue placement supports facial structure and reduces unnecessary tension." },
  { title: "Breathing", text: "Improve breathing patterns to support posture, reduce tension, and enhance overall facial balance." },
  { title: "Soft tissue work", text: "Use gentle techniques to release tension and activate key facial areas for a more lifted appearance." },
  { title: "Consistency", text: "Turn small daily actions into visible facial definition and long-term results." },
];
---
<div class="grid grid--2">
  {steps.map((s, i) => (
    <div class="card">
      <p class="step-kicker">Step {i + 1}</p>
      <h3 class="h3">{s.title}</h3>
      <p class="muted">{s.text}</p>
    </div>
  ))}
</div>
