---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/ui/Section.astro";

const posts = [
  { title: "What Is a Harmonious Face — and Why It Changes Over Time", href: "/blog/what-is-a-harmonious-face-and-why-it-changes-over-time" },
  { title: "Can Facial Exercises Really Change Your Face?", href: "/blog/can-facial-exercises-really-change-your-face" },
  { title: "A Natural Way to Lift and Define Your Face — Without Injections", href: "/blog/a-natural-way-to-lift-and-define-your-face-without-injections" },
];
---
<BaseLayout title="Blog • Facial Volume Harmony by Alina">
  <Section title="Blog">
    <div class="card">
      <p class="muted">
        Learn how your face changes — and what you can do to support natural lift and definition.
      </p>
      <ul class="bullets">
        {posts.map((p) => (
          <li><a href={p.href}>{p.title}</a></li>
        ))}
      </ul>
    </div>
  </Section>
</BaseLayout>
