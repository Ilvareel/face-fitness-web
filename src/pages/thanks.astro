---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";
import { getCheckoutUrl } from "../lib/checkout";

const checkout = getCheckoutUrl({ content: "thanks" });
---

<BaseLayout title="Thank you! • Facial Volume Harmony">
  <Section title="Thank you!">
    <div class="card">
      <p class="muted" style="max-width:70ch;">
        You’re all set 🎉
      </p>
      <p class="muted" style="max-width:70ch;">
        Your $20 discount code has just been sent to your email.
      </p>

      <h3 class="h3" style="margin-top:16px;">Didn’t receive the email?</h3>
      <ul class="bullets">
        <li>Check your Spam or Promotions tab (Gmail)</li>
        <li>Search for “Facial Volume Harmony”</li>
        <li>Try refreshing your inbox</li>
      </ul>

      <p class="muted" style="max-width:70ch;">
        Delivery may take 1–2 minutes.
      </p>

      <h3 class="h3" style="margin-top:16px;">What’s next</h3>
      <ul class="bullets">
        <li>Open the email and copy your discount code</li>
        <li>Use it at checkout (applies to the full program)</li>
        <li>Start exploring the articles to understand the approach</li>
      </ul>

      <div class="stack" style="margin-top:14px;">
        <Button
          href={checkout}
          variant="primary"
          data-ff-event="cta_click"
          data-ff-content="thanks"
          data-ff-outbound="checkout"
        >
          View the program
        </Button>
        <a class="btn btn--secondary" href="/">Back to home</a>
      </div>
    </div>
  </Section>
</BaseLayout>
