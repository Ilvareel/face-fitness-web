---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../lib/site";

import HeroSection from "../components/home/HeroSection.astro";
import SocialProofSection from "../components/home/SocialProofSection.astro";
import BenefitsSection from "../components/home/BenefitsSection.astro";
import MethodSection from "../components/home/MethodSection.astro";
import CourseSection from "../components/home/CourseSection.astro";
import FAQSection from "../components/home/FAQSection.astro";
import FreeTipsSection from "../components/home/FreeTipsSection.astro";

const origin = new URL(Astro.request.url).origin;

// Week 5 – Schema.org (JSON-LD): homepage Course structured data
const homepageSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "@id": `${origin}/#course`,
  "name": "Facial Volume Harmony — Natural Facial Training Program",
  "description":
    "A structured, non-invasive facial training program that combines facial exercises, tongue posture, breathing, and gentle manual techniques to support facial balance, natural volume, and jawline definition.",
  "provider": {
    "@type": "Organization",
    "@id": `${origin}/#organization`,
    "name": SITE.name,
    "url": `${origin}/`,
  },
  "url": `${origin}/`,
  "inLanguage": "en",
};
---

<!-- Week 5 – SEO/OG meta: per-page title/description/ogType/ogImage -->
<!-- Edit these props if you want to change how the page appears in Google + social previews. -->
<!-- Week 5 – Accessibility improvements: avoid nested <main> landmarks. -->

<BaseLayout
  title="Natural Facial Training Program"
  description="A structured, non-invasive facial training program that combines facial exercises, tongue posture, breathing, and gentle manual techniques to support facial balance, natural volume, and jawline definition."
  ogType="website"
  ogImage="https://cdn.facialvolumeharmony.com/og-images/og_hero-poster.png"
  schema={homepageSchema}
>
  <HeroSection />
  <SocialProofSection />
  <BenefitsSection />
  <MethodSection />
  <CourseSection />
  <FAQSection />
  <FreeTipsSection />
</BaseLayout>